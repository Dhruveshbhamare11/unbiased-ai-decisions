# Unbiased AI Decision Platform
# Environment Variables Template
# Copy this file to .env.local and fill in your actual values if connecting to real services.
# Note: The app defaults to DEMO MODE using mockData.js if Firebase/Backend is not setup.

# ==========================================
# 1. FIREBASE AUTHENTICATION & STORAGE
# Get these from your Firebase Console -> Project Settings
# ==========================================
VITE_FIREBASE_API_KEY="your-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"

# ==========================================
# 2. FASTAPI BACKEND CONNECTION (Phase 2)
# URL of your Python backend deployed on Replit/Cloud Run
# ==========================================
VITE_BACKEND_URL="http://localhost:8000"
